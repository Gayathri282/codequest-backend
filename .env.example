# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (Supabase Postgres) ─────────────────
# Get from: Supabase → Settings → Database → URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Supabase Auth ────────────────────────────────
# Get from: Supabase → Settings → API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."   # Service role key (secret — never expose to frontend)

# ─── JWT ──────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ─── Razorpay (Payments) ──────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# ─── Bunny.net (Video CDN) ────────────────────────
# Get from: https://panel.bunny.net → API Keys
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_STORAGE_ZONE="codequest-videos"
BUNNY_CDN_URL="https://codequest.b-cdn.net"
BUNNY_LIBRARY_ID="12345"

# ─── Supabase Storage (Thumbnails, Docs) ──────────
SUPABASE_STORAGE_BUCKET="codequest-assets"

# ─── Email (Resend.com) ───────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@codequest.in"

# ─── Frontend URL (for CORS) ──────────────────────
FRONTEND_URL="http://localhost:5173"
# In production: FRONTEND_URL="https://codequest.vercel.app"
