// backend/prisma/schema.prisma
// MongoDB + Prisma schema for CodeQuest

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PARENT
  ADMIN
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum SessionType {
  VIDEO
  DOCUMENT
  QUIZ
  CODE
  BOSS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(uuid()) @map("_id")
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  plan         Plan     @default(FREE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  username     String?  @unique
  displayName  String?
  avatarEmoji  String?  @default("🐸")
  age          Int?
  xp           Int      @default(0)
  coins        Int      @default(0)
  level        Int      @default(1)
  streakDays   Int      @default(0)
  lastActiveAt DateTime?

  resetToken       String?
  resetTokenExpiry DateTime?

  parentId String?
  parent   User?  @relation("ParentChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children User[] @relation("ParentChildren")

  progress     Progress[]
  payments     Payment[]
  earnedBadges UserBadge[]

  @@map("users")
}

model Course {
  id               String   @id @default(uuid()) @map("_id")
  title            String
  emoji            String
  description      String?
  color            String   @default("#00C8E8")
  subject          String
  ageGroup         String   @default("5-13")
  order            Int      @default(0)
  isPublished      Boolean  @default(false)
  isLocked         Boolean  @default(true)
  unlocksAfter     String?
  totalXp          Int      @default(0)
  freeSessionCount Int      @default(4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions Session[]
  progress Progress[]

  @@map("courses")
}

model Session {
  id       String @id @default(uuid()) @map("_id")
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  title       String
  type        SessionType
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  xpReward    Int      @default(50)
  coinsReward Int      @default(5)
  durationMins Int     @default(5)

  videoUrl    String?
  videoThumb  String?
  hasIde      Boolean @default(false)
  missionText String?
  docContent  String?
  starterCode String?
  solutionCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizQuestions QuizQuestion[]
  progress      Progress[]

  @@map("sessions")
}

model QuizQuestion {
  id        String  @id @default(uuid()) @map("_id")
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  question      String
  emoji         String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  explanation   String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("quiz_questions")
}

model Progress {
  id        String  @id @default(uuid()) @map("_id")
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id])
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  completed   Boolean   @default(false)
  stars       Int       @default(0)
  xpEarned    Int       @default(0)
  coinsEarned Int       @default(0)
  completedAt DateTime?

  videoExitSeconds Int?
  videoMaxSeconds  Int?
  videoDuration    Int?

  @@unique([userId, sessionId])
  @@map("progress")
}

model EditorDraft {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])

  // Stored as an array of { name, content } objects.
  files     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, sessionId])
  @@map("editor_drafts")
}

model Badge {
  id          String @id @default(uuid()) @map("_id")
  emoji       String
  name        String
  description String
  condition   String

  earnedBy UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid()) @map("_id")
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Payment {
  id     String @id @default(uuid()) @map("_id")
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  plan     Plan
  amount   Int
  currency String        @default("INR")
  status   PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Setting {
  key       String   @id @map("_id")
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
